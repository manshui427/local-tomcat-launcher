{
  "name": "local-tomcat-launcher",
  "displayName": "Local Tomcat Launcher",
  "description": "在VSCode中快速启动/停止/重启/刷新本机Tomcat，支持实时编译和热加载",
  "version": "1.0.1",
  "publisher": "manshui",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/manshui/local-tomcat-launcher"
  },
  "bugs": {
    "url": "https://github.com/manshui/local-tomcat-launcher/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "tomcat",
    "tomcat launcher",
    "java",
    "servlet",
    "jsp",
    "maven",
    "war",
    "hot reload",
    "hot swap",
    "debug",
    "jpda",
    "java web",
    "spring",
    "local server",
    "deploy"
  ],
  "extensionDependencies": [
    "redhat.java"
  ],
  "activationEvents": [
    "onLanguage:java",
    "workspaceContains:pom.xml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "local-tomcat-launcher.start",
        "title": "启动Tomcat",
        "icon": "$(play)"
      },
      {
        "command": "local-tomcat-launcher.stop",
        "title": "停止Tomcat",
        "icon": "$(debug-stop)"
      },
      {
        "command": "local-tomcat-launcher.restart",
        "title": "重启Tomcat",
        "icon": "$(sync)"
      },
      {
        "command": "local-tomcat-launcher.refresh",
        "title": "刷新Tomcat",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "local-tomcat-launcher.start",
          "group": "navigation@10"
        },
        {
          "command": "local-tomcat-launcher.stop",
          "group": "navigation@11"
        },
        {
          "command": "local-tomcat-launcher.restart",
          "group": "navigation@12"
        },
        {
          "command": "local-tomcat-launcher.refresh",
          "group": "navigation@13"
        }
      ]
    },
    "configuration": {
      "title": "Tomcat配置",
      "properties": {
        "support.tomcat.home": {
          "type": "string",
          "default": "",
          "description": "Tomcat安装路径。留空则使用插件内置的 resources/tomcat9",
          "scope": "workspace"
        },
        "support.tomcat.port": {
          "type": "number",
          "default": 8080,
          "description": "Tomcat HTTP发布端口",
          "scope": "workspace",
          "minimum": 1,
          "maximum": 65535
        },
        "support.tomcat.debugPort": {
          "type": "number",
          "default": 5005,
          "description": "Tomcat Debug端口",
          "scope": "workspace",
          "minimum": 1,
          "maximum": 65535
        },
        "support.tomcat.contextPath": {
          "type": "string",
          "default": "dev",
          "description": "Tomcat部署名称",
          "scope": "workspace"
        },
        "support.tomcat.vmOptions": {
          "type": "string",
          "default": "",
          "description": "Tomcat启动时使用的VM参数",
          "scope": "workspace"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^6.0.3",
    "vscode": "^1.1.37"
  }
}
